---
import SizeSwitch from './SizeSwitch.astro';
const { lang, slug } = Astro.props;
---
<header class="masthead">
  <div class="masthead-inner">
    <a class="masthead-section masthead-brand" href="/" style="font-size:14px">← Glossa</a>
    <span class="masthead-meta">
      <span class="lang-switch">
        {lang === 'en' ? <span class="lang-active">EN</span> : <a href={`/articles/${slug}/en/`} class="lang-link">EN</a>}
        <span class="lang-sep">·</span>
        {lang === 'es' ? <span class="lang-active">ES</span> : <a href={`/articles/${slug}/es/`} class="lang-link">ES</a>}
      </span>
      <SizeSwitch />
    </span>
  </div>
</header>
