---
const { label = 'Comparison', title, subtitle, source, leftLabel = '', rightLabel = '', rows = [] } = Astro.props;
---
<figure class="exhibit">
  <div class="exhibit-frame">
    <div class="exhibit-label">{label}</div>
    {title && <div class="exhibit-title">{title}</div>}
    {subtitle && <div class="exhibit-subtitle">{subtitle}</div>}
    <div class="comparison">
      <div class="comparison-headers">
        <div class="comparison-header">{leftLabel}</div>
        <div class="comparison-header">{rightLabel}</div>
      </div>
      {rows.map(r => (
        <div class="comparison-row">
          <div class="comparison-cell comparison-cell-left" data-side-label={leftLabel}>{r.left}</div>
          <div class="comparison-cell comparison-cell-right" data-side-label={rightLabel}>{r.right}</div>
        </div>
      ))}
    </div>
    {source && <div class="exhibit-source" set:html={`<strong>Source.</strong> ${source}`} />}
  </div>
</figure>
