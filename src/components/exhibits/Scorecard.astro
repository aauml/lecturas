---
const { label = 'Scorecard', title, subtitle, source, columns = [], rows = [] } = Astro.props;
const colCount = columns.length;

function renderValue(v) {
  if (v === true || v === '✓') return { mark: '✓', cls: 'scorecard-mark scorecard-mark-yes' };
  if (v === false || v === '✗') return { mark: '✗', cls: 'scorecard-mark scorecard-mark-no' };
  return { mark: String(v), cls: 'scorecard-text' };
}
---
<figure class="exhibit">
  <div class="exhibit-frame">
    <div class="exhibit-label">{label}</div>
    {title && <div class="exhibit-title">{title}</div>}
    {subtitle && <div class="exhibit-subtitle">{subtitle}</div>}
    <div class="scorecard" style={`--col-count: ${colCount}`}>
      <div class="scorecard-row scorecard-row-header">
        <div class="scorecard-cell scorecard-cell-corner" aria-hidden="true"></div>
        {columns.map(c => <div class="scorecard-cell scorecard-cell-header">{c}</div>)}
      </div>
      {rows.map(r => (
        <div class="scorecard-row">
          <div class="scorecard-cell scorecard-cell-rowlabel">{r.label}</div>
          {r.values.map((v, vi) => {
            const { mark, cls } = renderValue(v);
            return (
              <div class={`scorecard-cell scorecard-cell-value ${cls}`} data-col={columns[vi]}>
                <span class="scorecard-mobile-col">{columns[vi]}</span>
                <span class="scorecard-mark-text">{mark}</span>
              </div>
            );
          })}
        </div>
      ))}
    </div>
    {source && <div class="exhibit-source" set:html={`<strong>Source.</strong> ${source}`} />}
  </div>
</figure>
