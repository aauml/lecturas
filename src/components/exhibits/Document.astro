---
const { label = 'Document', title, subtitle, source, header = '', body = [], stamp = '' } = Astro.props;
---
<figure class="exhibit">
  <div class="exhibit-frame">
    <div class="exhibit-label">{label}</div>
    {title && <div class="exhibit-title">{title}</div>}
    {subtitle && <div class="exhibit-subtitle">{subtitle}</div>}
    <div class="document-mock">
      {header && <div class="document-mock-header">{header}</div>}
      <div class="document-mock-body">
        {body.map(line => <div class="document-mock-line">{line}</div>)}
      </div>
      {stamp && <div class="document-mock-stamp">{stamp}</div>}
    </div>
    {source && <div class="exhibit-source" set:html={`<strong>Source.</strong> ${source}`} />}
  </div>
</figure>
