---
const { label = 'Comparison', title, subtitle, source, items = [], unit = '' } = Astro.props;
const max = Math.max(...items.map(i => i.value));
---
<figure class="exhibit">
  <div class="exhibit-frame">
    <div class="exhibit-label">{label}</div>
    {title && <div class="exhibit-title">{title}</div>}
    {subtitle && <div class="exhibit-subtitle">{subtitle}</div>}
    <div class="bars">
      {items.map(it => {
        const pct = (it.value / max) * 100;
        return (
          <div class={`bars-row${it.accent ? ' bars-row-accent' : ''}`}>
            <div class="bars-label">
              <span class="bars-label-text">{it.label}</span>
              {it.note && <span class="bars-label-note">{it.note}</span>}
            </div>
            <div class="bars-track" role="presentation">
              <div class="bars-fill" style={`--bar-pct: ${pct}%`}></div>
            </div>
            <div class="bars-value">{it.display ?? `${it.value}${unit}`}</div>
          </div>
        );
      })}
    </div>
    {source && <div class="exhibit-source" set:html={`<strong>Source.</strong> ${source}`} />}
  </div>
</figure>
