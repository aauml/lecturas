---
import { getCollection } from 'astro:content';
import CoverLayout from '../layouts/CoverLayout.astro';

const allArticles = await getCollection('articles');
const enArticles = allArticles
  .filter(a => a.data.language === 'en' && !a.data.hidden)
  .map(a => ({ ...a, slug: a.id.split('/')[0].replace(/\.mdx$/, '') }))
  .sort((a, b) => b.data.sortDate.localeCompare(a.data.sortDate));

const [featured, ...rest] = enArticles;

// Topic filter set: the union of all topics, ranked by frequency, capped.
const freq = new Map();
for (const a of enArticles) for (const t of (a.data.topics || [])) freq.set(t, (freq.get(t) || 0) + 1);
const topics = [...freq.entries()].sort((x, y) => y[1] - x[1]).slice(0, 8).map(e => e[0]);
const keyOf = (a) => (a.data.topics || []).join('|');
---
<CoverLayout>
  <section class="cover">
    <h1 class="cover-wordmark">Glossa<span class="wm-dot">.</span></h1>
    <p class="cover-tagline">Personal annotated readings. I direct, AI executes.</p>
    <p class="cover-credo">The ideas, analysis, and arguments are mine; the research, verification, and writing are done by AI. Every claim is searched, cross-checked, and traced to a real source. <strong>Grounded, not invented.</strong></p>
  </section>

  <section class="contents">
    <div class="cover-filter">
      <div class="filter-topics" id="filter">
        <button class="f on" data-t="all">All</button>
        {topics.map(t => <button class="f" data-t={t}>{t}</button>)}
      </div>
      <span class="cover-count">{enArticles.length} {enArticles.length === 1 ? 'piece' : 'pieces'} · 2026</span>
    </div>

    {featured && (
      <a class="article-card featured" href={`/articles/${featured.slug}/en/`} data-topics={keyOf(featured)}>
        <div class="featured-tag">Most recent</div>
        <div class="article-card-meta">
          <span class="article-card-number">{featured.data.issue}</span>
          <span class="article-card-date">{featured.data.date}</span>
          {featured.data.track && featured.data.track !== 'general' && <span class="article-card-track">{featured.data.track}</span>}
        </div>
        <h2 class="article-card-title" set:html={featured.data.titleHTML} />
        <p class="article-card-dek" set:html={featured.data.coverDek} />
        <ul class="article-card-topics">
          {featured.data.topics.map(t => <li>{t}</li>)}
        </ul>
      </a>
    )}

    <div id="list">
      {rest.map((a) => (
        <a class="article-card" href={`/articles/${a.slug}/en/`} data-topics={keyOf(a)}>
          <div class="article-card-meta">
            <span class="article-card-number">{a.data.issue}</span>
            <span class="article-card-date">{a.data.date}</span>
            {a.data.track && a.data.track !== 'general' && <span class="article-card-track">{a.data.track}</span>}
          </div>
          <h2 class="article-card-title" set:html={a.data.titleHTML} />
          <p class="article-card-dek" set:html={a.data.coverDek} />
          <ul class="article-card-topics">
            {a.data.topics.map(t => <li>{t}</li>)}
          </ul>
        </a>
      ))}
    </div>
  </section>

  <footer class="footer">
    <span>Personal · No ads · No tracking</span>
    <a href="https://github.com/aauml/glossa">github</a>
  </footer>

  <script is:inline>
    (function () {
      var btns = document.querySelectorAll('.cover-filter .f');
      var cards = document.querySelectorAll('.article-card[data-topics]');
      btns.forEach(function (b) {
        b.addEventListener('click', function () {
          var t = b.dataset.t;
          btns.forEach(function (x) { x.classList.toggle('on', x === b); });
          cards.forEach(function (c) {
            var has = t === 'all' || ('|' + c.dataset.topics + '|').indexOf('|' + t + '|') > -1;
            if (has) c.removeAttribute('hidden'); else c.setAttribute('hidden', '');
          });
        });
      });
    })();
  </script>
</CoverLayout>
